# ──────────────────────────────────────────────────
# FocusQuest Environment Variables
# ──────────────────────────────────────────────────
# Copy this file to .env and fill in values.
# NEVER commit .env to Git. Appflow injects these at build time.
# ──────────────────────────────────────────────────

# Firebase Configuration (per environment: dev / staging / prod)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Backend Services
VITE_RAFFLE_SERVICE_URL=

# Error Tracking
VITE_SENTRY_DSN=

# Feature Flags
VITE_FEATURE_RAFFLE_ENABLED=true
VITE_FEATURE_TIMEKEEPER_V2=false
VITE_FEATURE_PARENT_TASKS=true
