rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Verification photos: user can upload to their own path, parent can read
    match /verification_photos/{userId}/{allPaths=**} {
      allow read: if request.auth != null && (
        request.auth.uid == userId ||
        // Check if requester is the parent (requires custom claims or Firestore lookup)
        request.auth.token.parentOf == userId
      );
      allow write: if request.auth != null &&
        request.auth.uid == userId &&
        request.resource.size < 10 * 1024 * 1024 && // Max 10MB
        request.resource.contentType.matches('image/.*'); // Images only
    }
  }
}
